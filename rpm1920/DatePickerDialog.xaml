<Window x:Class="rpm1920.DatePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:rpm1920"
        mc:Ignorable="d"
        Title="DatePickerDialog" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите дату для отчета о движении" 
                   FontWeight="Bold" FontSize="14" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <DatePicker x:Name="dpDate" Grid.Row="1" Width="200" Height="30" 
                    SelectedDate="2025-03-12" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="OK" Width="80" Height="35" Margin="5" Click="BtnOk_Click" 
                    Background="#27AE60" Foreground="White" IsDefault="True"/>
            <Button Content="Отмена" Width="80" Height="35" Margin="5" Click="BtnCancel_Click" 
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
