<Window x:Class="rpm1920.MovementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:rpm1920"
        mc:Ignorable="d"
        Title="MovementWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="Управление деталями" 
                       FontSize="16" FontWeight="Bold" Foreground="White" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма добавления/редактирования -->
        <Border Grid.Row="1" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" 
                Padding="10" Margin="0,0,0,10" Background="#ECF0F1">

            <!-- ОБЕРТЫВАЕМ ВСЕ В StackPanel -->
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="Код:" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtCode" Grid.Column="1" Width="80" Margin="5" Height="25"/>

                    <Label Content="Наименование:" Grid.Column="2" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtName" Grid.Column="3" Width="180" Margin="5" Height="25"/>

                    <Label Content="Количество:" Grid.Column="4" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtQuantity" Grid.Column="5" Width="80" Margin="5" Height="25"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnAdd" Content="Добавить" Width="100" Height="35" Margin="5" 
                            Click="BtnAdd_Click" Background="#27AE60" Foreground="White"/>
                    <Button x:Name="btnUpdate" Content="Обновить" Width="100" Height="35" Margin="5" 
                            Click="BtnUpdate_Click" Background="#3498DB" Foreground="White"/>
                    <Button x:Name="btnClear" Content="Очистить" Width="100" Height="35" Margin="5" 
                            Click="BtnClear_Click" Background="#95A5A6" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Таблица с деталями -->
        <DataGrid x:Name="dgvMovement" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True"
                  SelectionChanged="DgvMovement_SelectionChanged"
                  AlternatingRowBackground="#F5F5F5" FontSize="13"
                  BorderBrush="#BDC3C7" BorderThickness="1"/>

        <!-- Кнопка удаления -->
        <Button x:Name="btnDelete" Grid.Row="3" Content="Удалить выбранную деталь" 
                Width="180" Height="35" HorizontalAlignment="Right" Margin="0,10,0,0"
                Click="BtnDelete_Click" Background="#E74C3C" Foreground="White"/>
    </Grid>
</Window>
