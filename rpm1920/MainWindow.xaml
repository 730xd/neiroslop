<Window x:Class="rpm1920.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:rpm1920"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="MainWindow" Height="800" Width="800">
     <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="📦 СКЛАДСКОЙ УЧЕТ | Практические работы №19, 20, 22" 
                       FontSize="16" FontWeight="Bold" Foreground="White" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Кнопки CRUD -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,10" HorizontalAlignment="Center">
            <Button x:Name="btnAdd" Content="ДОБАВИТЬ" Width="100" Height="35" Margin="3"
                    Click="BtnAdd_Click" Background="#27AE60" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="btnEdit" Content="РЕДАКТИРОВАТЬ" Width="120" Height="35" Margin="3"
                    Click="BtnEdit_Click" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="btnDelete" Content="УДАЛИТЬ" Width="100" Height="35" Margin="3"
                    Click="BtnDelete_Click" Background="#E74C3C" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="btnRefresh" Content="ОБНОВИТЬ" Width="100" Height="35" Margin="3"
                    Click="BtnRefresh_Click" Background="#95A5A6" Foreground="White" FontWeight="Bold"/>
        </WrapPanel>

        <!-- Панель поиска -->
        <Border Grid.Row="2" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" 
                Padding="10" Margin="0,0,0,10" Background="#ECF0F1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍 Поиск:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtSearch" Width="250" Height="30" Margin="0,0,10,0"/>
                    <Button x:Name="btnSearch" Content="Найти" Width="80" Height="30" 
                            Click="BtnSearch_Click" Background="#3498DB" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Панель отчетов ПР19 и ПР22 -->
        <Border Grid.Row="3" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" 
        Padding="10" Margin="0,0,0,10" Background="#F9E79F">
            <StackPanel>
                <TextBlock Text="📊 ОТЧЕТЫ" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                <!-- Все кнопки в одном WrapPanel с одинаковыми отступами -->
                <WrapPanel HorizontalAlignment="Center">

                    <!-- ПР19 Задание 2 -->
                    <Button x:Name="btnMonthReport" Content="Поступление за месяц" 
                    Width="180" Height="35" Margin="5" Click="BtnMonthReport_Click" 
                    Background="#F39C12" Foreground="White" FontWeight="Bold"/>

                    <!-- ПР19 Задание 3 -->
                    <Button x:Name="btnCostReport" Content="Стоимость по требованиям" 
                    Width="180" Height="35" Margin="5" Click="BtnCostReport_Click" 
                    Background="#F39C12" Foreground="White" FontWeight="Bold"/>

                    <!-- ПР22 Задание 1 -->
                    <Button x:Name="btnStockBalance" Content="Остаток на складе" 
                    Width="180" Height="35" Margin="5" Click="BtnStockBalance_Click" 
                    Background="#8E44AD" Foreground="White" FontWeight="Bold"/>

                    <!-- ПР22 Задание 2 -->
                    <Button x:Name="btnMovementByDate" Content="Движение за дату" 
                    Width="180" Height="35" Margin="5" Click="BtnMovementByDate_Click" 
                    Background="#8E44AD" Foreground="White" FontWeight="Bold"/>

                    <!-- ПР22 Задание 4 -->
                    <Button x:Name="btnStockValue" Content="Стоимость на складе" 
                    Width="180" Height="35" Margin="5" Click="BtnStockValue_Click" 
                    Background="#8E44AD" Foreground="White" FontWeight="Bold"/>

                    <!-- ПР22 Задание 5 -->
                    <Button x:Name="btnMostIssued" Content="Самая выдаваемая деталь" 
                    Width="180" Height="35" Margin="5" Click="BtnMostIssued_Click" 
                    Background="#8E44AD" Foreground="White" FontWeight="Bold"/>

                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="dgvData" Grid.Row="4" AutoGenerateColumns="True" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" FontSize="12"
                  SelectionMode="Single" BorderBrush="#BDC3C7"
                  SelectionChanged="DgvData_SelectionChanged"/>
    </Grid>
</Window>
