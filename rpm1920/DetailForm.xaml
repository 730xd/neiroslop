<Window x:Class="rpm1920.DetailForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:rpm1920"
        mc:Ignorable="d"
        Title="DetailForm" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="lblTitle" Text="ДОБАВЛЕНИЕ НОВОЙ ДЕТАЛИ" 
                   FontSize="16" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Код детали -->
        <Border Grid.Row="1" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" 
                Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Код детали:" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox x:Name="txtCode" Grid.Column="1" Height="30"/>
            </Grid>
        </Border>

        <!-- Наименование -->
        <Border Grid.Row="2" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" 
                Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Наименование:" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox x:Name="txtName" Grid.Column="1" Height="30"/>
            </Grid>
        </Border>

        <!-- Количество -->
        <Border Grid.Row="3" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" 
                Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Количество:" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox x:Name="txtQuantity" Grid.Column="1" Height="30"/>
            </Grid>
        </Border>

        <!-- Цена -->
        <Border Grid.Row="4" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" 
                Padding="10" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Цена:" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPrice" Grid.Column="1" Height="30"/>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnSave" Content="СОХРАНИТЬ" Width="120" Height="40" Margin="10"
                    Click="BtnSave_Click" Background="#27AE60" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="btnCancel" Content="ОТМЕНА" Width="120" Height="40" Margin="10"
                    Click="BtnCancel_Click" Background="#E74C3C" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
